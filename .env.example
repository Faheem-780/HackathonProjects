# =============================================================================
# Snippet Library - Environment Variables
# =============================================================================
# Copy this file as ".env" in the same directory as app.py
# Fill in the values below to enable optional features.

# -----------------------------------------------------------------------------
# AI Code Explanation (OPTIONAL)
# -----------------------------------------------------------------------------
# Pick ONE provider below. Gemini is recommended (free, fast, generous tier).
#
# Option 1: Google Gemini (RECOMMENDED - free)
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Option 2: Groq (free, no credit card)
# Get your key: https://console.groq.com/
GROQ_API_KEY=

# Option 3: OpenAI (paid)
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
# Gemini models: gemini-2.0-flash (fast), gemini-2.5-flash (smart), gemini-2.5-pro (best)
# Groq models:   llama-3.1-8b-instant, llama-3.3-70b-versatile, gemma2-9b-it
# OpenAI models: gpt-4o-mini (cheap), gpt-4o (best)
AI_MODEL=gemini-2.0-flash

# Base URL (auto-detected per provider, only change if using a custom endpoint)
# Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
# Groq:   https://api.groq.com/openai/v1
# OpenAI: https://api.openai.com/v1
# AI_BASE_URL=
